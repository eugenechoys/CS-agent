OPENAI_API_KEY=your_openai_api_key

# Optional: use a pre-seeded Choys demo token instead of OTP sign-in.
CHOYS_DEMO_ACCESS_TOKEN=

# Optional: default backend environment for the OTP and read-only demo APIs.
CHOYS_API_ENV=dev
# Optional: env-specific overrides. Prefer these over CHOYS_API_BASE_URL when supporting both DEV and PROD.
CHOYS_API_BASE_URL_DEV=https://api.dev.choysapp.com
CHOYS_API_BASE_URL_PROD=https://prodapi.choysapp.com
# Optional: single explicit override. Leave unset if you want the UI env switch to change hosts.
# CHOYS_API_BASE_URL=https://api.dev.choysapp.com
CHOYS_APP_PLATFORM=choys-web-app
